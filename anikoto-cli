#!/bin/sh
# anikoto-cli — watch anime in mpv via AniList search + megaplay.buzz streams
# No scraping of Cloudflare-protected sites needed
# Dependencies: curl, fzf, mpv (or vlc)

version_number="2.0.0"
megaplay="https://megaplay.buzz"
agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36"

# ── defaults ──────────────────────────────────────────────────────────────────
mode="${ANI_CLI_MODE:-sub}"
player="${ANI_CLI_PLAYER:-mpv}"
download_mode=0
ep_range=""
histfile="${XDG_STATE_HOME:-$HOME/.local/state}/anikoto-cli/history"

# ── helpers ───────────────────────────────────────────────────────────────────
die()  { printf "\033[1;31m%s\033[0m\n" "$*" >&2; exit 1; }
info() { printf "\033[1;34m:: %s\033[0m\n" "$*" >&2; }
ok()   { printf "\033[1;32m✓ %s\033[0m\n" "$*" >&2; }
dep_ch() {
    for dep; do command -v "$dep" >/dev/null || die "Missing: $dep"; done
}
launcher() { fzf --reverse --cycle --prompt "$1 > "; }

# ── help ──────────────────────────────────────────────────────────────────────
help_info() {
    printf "
Usage: %s [options] [query]

Options:
  -e, --episode <n>     Episode number or range (e.g. 3 or 5-10)
  -m, --mode <m>        sub or dub (default: sub)
  -d, --download        Download instead of playing
  -c, --continue        Resume from history
  -D, --delete          Clear history
  -v, --vlc             Use VLC instead of mpv
  -V, --version         Print version
  -h, --help            This help

Examples:
  %s clannad
  %s snafu
  %s -m dub -e 5 my hero academia
  %s -e 1-12 demon slayer
  %s -c
\n" "${0##*/}" "${0##*/}" "${0##*/}" "${0##*/}" "${0##*/}" "${0##*/}"
    exit 0
}

# ── history ───────────────────────────────────────────────────────────────────
save_history() {
    # mal_id|title|last_ep|mode|episodes
    mkdir -p "$(dirname "$histfile")"
    tmp=$(mktemp)
    grep -v "^${1}|" "$histfile" 2>/dev/null > "$tmp" || true
    printf "%s|%s|%s|%s|%s\n" "$1" "$2" "$3" "$4" "$5" | cat - "$tmp" > "$histfile"
    rm -f "$tmp"
}

pick_from_history() {
    [ -f "$histfile" ] || die "No history yet."
    entry=$(awk -F'|' '{printf "%s — ep%s [%s]\t%s\t%s\n", $2, $3, $4, $1, $5}' "$histfile" \
        | launcher "Resume")
    [ -z "$entry" ] && die "Nothing selected."
    printf '%s' "$entry"
}

# ── step 1: search AniList ────────────────────────────────────────────────────
search_anilist() {
    query="$1"
    # escape quotes in query for JSON
    safe=$(printf '%s' "$query" | sed 's/"/\\"/g')
    body="{\"query\":\"query(\$s:String){Page(perPage:20){media(search:\\\"\${safe}\\\",type:ANIME,sort:SEARCH_MATCH){title{english romaji}idMal episodes}}}\"}"
    # simpler: build with printf
    curl -s -X POST "https://graphql.anilist.co" \
        -H "Content-Type: application/json" \
        --data-raw "{\"query\":\"query{Page(perPage:20){media(search:\\\"${safe}\\\",type:ANIME,sort:SEARCH_MATCH){title{english romaji}idMal episodes}}}\"}" \
        | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    for item in d['data']['Page']['media']:
        eng   = item['title'].get('english') or ''
        rom   = item['title'].get('romaji')  or ''
        title = eng if eng else rom
        mal   = item.get('idMal') or ''
        eps   = item.get('episodes') or '?'
        print(f'{title}\t{mal}\t{eps}')
except Exception as e:
    import sys; print(f'AniList error: {e}', file=sys.stderr)
"
}

# ── step 2: get stream URL from megaplay ──────────────────────────────────────
# megaplay.buzz/stream/mal/<mal-id>/<ep>/<sub|dub>
# This is an embed page — we need to extract the getSources call from it

get_stream() {
    mal_id="$1"
    ep_num="$2"
    lang="$3"

    embed_url="${megaplay}/stream/mal/${mal_id}/${ep_num}/${lang}"
    info "Fetching embed: $embed_url"

    html=$(curl -s -A "$agent" \
        -H "Referer: ${megaplay}/" \
        "$embed_url")

    # Extract the numeric data-id used for getSources
    id=$(printf '%s' "$html" | grep -oE 'data-id="[0-9]+"' | head -1 | grep -oE '[0-9]+')

    if [ -z "$id" ]; then
        # try alternate pattern: id in JS
        id=$(printf '%s' "$html" | grep -oE '"id"\s*:\s*"?[0-9]+"?' | head -1 | grep -oE '[0-9]+')
    fi

    [ -z "$id" ] && return 1

    info "Source ID: $id"

    sources=$(curl -s -A "$agent" \
        -H "Referer: ${megaplay}/" \
        "${megaplay}/stream/getSources?id=${id}")

    printf '%s' "$sources" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    src = d.get('sources', {})
    if isinstance(src, dict):
        url = src.get('file','')
    elif isinstance(src, list) and src:
        url = src[0].get('file','')
    else:
        url = ''
    print(url)
except:
    pass
"
}

# ── play or download ──────────────────────────────────────────────────────────
play_episode() {
    url="$1"; title="$2"
    if [ "$download_mode" = "1" ]; then
        out="$(printf '%s' "$title" | tr ' /' '_-' | tr -dc 'A-Za-z0-9_.-').mp4"
        info "Downloading: $out"
        curl -L -A "$agent" -H "Referer: ${megaplay}/" --progress-bar -o "$out" "$url"
        ok "Saved: $out"
    else
        info "Playing: $title"
        case "$player" in
            *vlc*) $player --http-referrer="${megaplay}/" "$url" ;;
            *)     $player --referrer="${megaplay}/" --title="$title" "$url" ;;
        esac
    fi
}

# ── main ──────────────────────────────────────────────────────────────────────
main() {
    dep_ch curl fzf python3

    query=""; from_history=0

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)     help_info ;;
            -V|--version)  printf "%s\n" "$version_number"; exit 0 ;;
            -d|--download) download_mode=1 ;;
            -v|--vlc)      player="vlc" ;;
            -c|--continue) from_history=1 ;;
            -D|--delete)   rm -f "$histfile" && printf "History cleared.\n" && exit 0 ;;
            -m|--mode)     shift; mode="$1" ;;
            -e|--episode|-r|--range) shift; ep_range="$1" ;;
            --dub) mode="dub" ;; --sub) mode="sub" ;;
            -*) die "Unknown option: $1" ;;
            *)  query="${query:+$query }$1" ;;
        esac
        shift
    done

    # ── pick series ───────────────────────────────────────────────────────────
    if [ "$from_history" = "1" ]; then
        entry=$(pick_from_history)
        mal_id=$(printf '%s' "$entry"    | cut -f2)
        series_title=$(awk -F'|' -v m="$mal_id" '$1==m{print $2;exit}' "$histfile")
        total_eps=$(awk -F'|' -v m="$mal_id" '$1==m{print $5;exit}' "$histfile")
        last_ep=$(awk -F'|' -v m="$mal_id" '$1==m{print $3;exit}' "$histfile")
        mode=$(awk -F'|' -v m="$mal_id" '$1==m{print $4;exit}' "$histfile")
        [ -z "$ep_range" ] && ep_range="$last_ep-$last_ep"
    else
        [ -z "$query" ] && printf "Search anime: " && read -r query
        [ -z "$query" ] && die "No query given."

        info "Searching: $query"
        results=$(search_anilist "$query")
        [ -z "$results" ] && die "No results for: $query"

        # show fzf with title + ep count
        selected=$(printf '%s' "$results" \
            | awk -F'\t' '{printf "%s  (%s eps)\t%s\t%s\n", $1, $3, $2, $3}' \
            | launcher "Select anime")
        [ -z "$selected" ] && die "Nothing selected."

        series_title=$(printf '%s' "$selected" | cut -f1 | sed 's/  ([0-9?]* eps)$//')
        mal_id=$(printf '%s' "$selected" | cut -f2)
        total_eps=$(printf '%s' "$selected" | cut -f3)

        [ -z "$mal_id" ] || [ "$mal_id" = "None" ] && \
            die "No MAL ID for '$series_title' — megaplay requires a MAL ID."
    fi

    info "Selected: $series_title  (MAL: $mal_id, Episodes: $total_eps)"

    # ── select episode(s) ─────────────────────────────────────────────────────
    if [ -z "$ep_range" ]; then
        # build episode list for fzf
        if [ "$total_eps" = "?" ] || [ -z "$total_eps" ]; then
            # unknown ep count — ask user
            printf "Episode number (or range e.g. 1-12): " && read -r ep_range
            [ -z "$ep_range" ] && die "No episode given."
            ep_clean=$(printf '%s' "$ep_range" | tr ' ' '-')
            ep_start=$(printf '%s' "$ep_clean" | cut -d'-' -f1)
            ep_end=$(printf '%s' "$ep_clean" | cut -d'-' -f2)
        else
            ep_num=$(seq 1 "$total_eps" | awk '{printf "Episode %s\t%s\n", $1, $1}' \
                | launcher "Select episode" | cut -f2)
            [ -z "$ep_num" ] && die "Nothing selected."
            ep_start="$ep_num"; ep_end="$ep_num"
        fi
    else
        ep_clean=$(printf '%s' "$ep_range" | tr ' ' '-')
        ep_start=$(printf '%s' "$ep_clean" | cut -d'-' -f1)
        ep_end=$(printf '%s' "$ep_clean" | cut -d'-' -f2)
        [ "$ep_end" = "$ep_start" ] && ep_end="$ep_start"
    fi

    # ── playback loop ─────────────────────────────────────────────────────────
    ep_num="$ep_start"
    while [ "$ep_num" -le "$ep_end" ]; do
        ep_label="${series_title} — Episode ${ep_num} [${mode}]"
        info "→ $ep_label"

        m3u8=$(get_stream "$mal_id" "$ep_num" "$mode")

        if [ -z "$m3u8" ]; then
            printf "\033[1;33mNo stream found for ep %s in %s mode.\033[0m\n" "$ep_num" "$mode" >&2
            # try the other mode as fallback
            other_mode="dub"; [ "$mode" = "dub" ] && other_mode="sub"
            info "Trying $other_mode as fallback..."
            m3u8=$(get_stream "$mal_id" "$ep_num" "$other_mode")
            [ -z "$m3u8" ] && die "No stream available for episode $ep_num."
            printf "\033[1;33mFalling back to %s\033[0m\n" "$other_mode" >&2
        fi

        ok "Stream found."
        play_episode "$m3u8" "$ep_label"
        save_history "$mal_id" "$series_title" "$ep_num" "$mode" "${total_eps:-?}"

        ep_num=$((ep_num + 1))

        if [ "$ep_num" -le "$ep_end" ] && [ "$download_mode" = "0" ]; then
            printf "Continue to episode %s? [Y/n] " "$ep_num"
            read -r ans
            case "$ans" in [Nn]*) break ;; esac
        fi
    done
}

main "$@"
